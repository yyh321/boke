---
import { extractToc } from '../lib/utils'

interface Props {
  content: string
}

const { content } = Astro.props
const toc = extractToc(content)
---

{toc.length > 0 && (
  <nav class="toc" aria-label="文章目录">
    <h2 class="toc-title">目录</h2>
    <ul class="toc-list">
      {toc.map((item) => (
        <li class={item.level === 3 ? 'toc-item-h3' : 'toc-item'}>
          <a href={`#${item.id}`} class="toc-link">
            {item.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const links = document.querySelectorAll('.toc-link')

  function setActiveLink(): void {
    const headings = document.querySelectorAll('h2, h3')
    let currentIndex = -1

    headings.forEach((heading, index) => {
      const rect = heading.getBoundingClientRect()
      if (rect.top <= 100) {
        currentIndex = index
      }
    })

    links.forEach((link, index) => {
      link.classList.toggle('active', index === currentIndex)
    })
  }

  window.addEventListener('scroll', setActiveLink, { passive: true })

  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault()
      const href = link.getAttribute('href')
      if (href) {
        const target = document.querySelector(href)
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' })
        }
      }
    })
  })
</script>

<style>
  .toc {
    position: sticky;
    top: 6rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .toc-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: theme('colors.gray.900');
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.dark) .toc-title {
    color: theme('colors.gray.100');
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item,
  .toc-item-h3 {
    margin-bottom: 0.25rem;
  }

  .toc-item-h3 {
    padding-left: 1rem;
  }

  .toc-link {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.8125rem;
    color: theme('colors.gray.500');
    border-radius: 0.375rem;
    transition: all 0.2s;
    text-decoration: none;
    border-left: 2px solid transparent;
  }

  :global(.dark) .toc-link {
    color: theme('colors.gray.400');
  }

  .toc-link:hover {
    color: theme('colors.gray.900');
    background: theme('colors.gray.50');
  }

  :global(.dark) .toc-link:hover {
    color: theme('colors.gray.100');
    background: theme('colors.gray.800');
  }

  .toc-link.active {
    color: theme('colors.primary.600');
    border-left-color: theme('colors.primary.500');
    font-weight: 500;
  }

  :global(.dark) .toc-link.active {
    color: theme('colors.primary.400');
    border-left-color: theme('colors.primary.400');
  }
</style>
