---

<footer class="border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50 mt-auto">
  <div class="container-main py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" class="text-lg font-bold bg-gradient-to-r from-primary-600 to-accent-600 bg-clip-text text-transparent">
          超越自我技术博客
        </a>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
          分享技术思考与生活感悟，用文字记录成长。超越自我的个人技术博客。
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">快速导航</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">首页</a></li>
          <li><a href="/categories" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">分类</a></li>
          <li><a href="/tags" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">标签</a></li>
          <li><a href="/about" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">关于</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">社交媒体</h3>
        <div class="flex gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
              aria-label={link.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={link.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800 text-center">
      <p class="text-sm text-gray-400 dark:text-gray-500">
        &copy; {currentYear} 超越自我技术博客. All rights reserved.
      </p>
    </div>
  </div>
</footer>
