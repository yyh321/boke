---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout
  title="关于我"
  description="了解我的个人背景、技能栈与项目经历"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="container-narrow py-16 animate-fade-in">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-8">
      关于我
    </h1>

    <div class="prose">
      <section class="mb-12">
        <h2>个人简介</h2>
        <p>
          我是一名热爱技术的前端开发者，专注于构建高性能、用户友好的 Web 应用。
          拥有多年前端开发经验，熟悉现代前端技术栈，包括 React、Vue、TypeScript、Astro 等。
        </p>
        <p>
          我相信技术是改变世界的力量，持续学习是保持竞争力的关键。
          在工作之余，我喜欢写技术博客、参与开源项目、探索新兴技术。
        </p>
      </section>

      <section class="mb-12">
        <h2>技能栈</h2>

        <h3>前端技术</h3>
        <ul>
          <li>HTML5 / CSS3 / JavaScript (ES6+)</li>
          <li>TypeScript</li>
          <li>React / Next.js / Vue / Nuxt</li>
          <li>Astro / Tailwind CSS</li>
          <li>Webpack / Vite / Turbopack</li>
        </ul>

        <h3>后端与工具</h3>
        <ul>
          <li>Node.js / Express / NestJS</li>
          <li>PostgreSQL / MongoDB / Redis</li>
          <li>Git / GitHub Actions / CI/CD</li>
          <li>Docker / Kubernetes</li>
          <li>AWS / Vercel / Netlify</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2>项目经历</h2>

        <h3>个人博客系统</h3>
        <p>基于 Astro 构建的高性能博客系统，支持 MDX 文章内容管理、全文搜索、RSS 订阅等功能。</p>
        <ul>
          <li>使用 Astro Content Collections 管理文章内容</li>
          <li>集成 Tailwind CSS 实现响应式设计</li>
          <li>实现完整的 SEO 优化和可访问性支持</li>
          <li>自动化部署到 Vercel 平台</li>
        </ul>

        <h3>在线代码编辑器</h3>
        <p>基于 WebContainer 技术的在线代码编辑与运行环境，支持多种编程语言。</p>
        <ul>
          <li>使用 Monaco Editor 作为代码编辑器核心</li>
          <li>通过 WebContainer 实现在浏览器端运行代码</li>
          <li>支持代码分享和协作编辑</li>
        </ul>
      </section>

      <section>
        <h2>联系我</h2>
        <p>如果你有任何问题或合作意向，欢迎通过以下方式联系我：</p>
        <ul>
          <li>Email: your-email@example.com</li>
          <li>GitHub: github.com/your-username</li>
          <li>Twitter: twitter.com/your-username</li>
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>
