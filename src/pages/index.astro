---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ArticleCard from '../components/ArticleCard.astro'
import { getCollection } from 'astro:content'
import { getSortedPosts, formatDate } from '../lib/utils'

const allPosts = await getCollection('blog')
const sortedPosts = getSortedPosts(allPosts)
const featuredPosts = sortedPosts.filter((p) => p.data.featured).slice(0, 3)
const recentPosts = sortedPosts.slice(0, 6)
---

<BaseLayout
  title="首页"
  description="于云浩技术博客 - 分享技术思考与生活感悟"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="container-main py-16 animate-fade-in">
    <div class="text-center mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4 text-balance">
        欢迎来到我的博客
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        分享技术思考与生活感悟，用文字记录成长。于云浩的个人技术博客。
      </p>
      <div class="flex justify-center gap-4 mt-8">
        <a href="/search" class="btn-primary">
          搜索文章
        </a>
        <a href="/about" class="btn-secondary">
          关于我
        </a>
      </div>
    </div>

    {featuredPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
          <span class="w-1 h-6 bg-primary-500 rounded-full" aria-hidden="true" />
          精选文章
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredPosts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      </section>
    )}

    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
        <span class="w-1 h-6 bg-primary-500 rounded-full" aria-hidden="true" />
        最新文章
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <ArticleCard post={post} />
        ))}
      </div>

      {sortedPosts.length > 6 && (
        <div class="text-center mt-8">
          <a href="/categories" class="btn-secondary">
            查看所有文章
          </a>
        </div>
      )}
    </section>
  </section>

  {sortedPosts.length === 0 && (
    <section class="container-main py-24 text-center">
      <p class="text-gray-400 dark:text-gray-500 text-lg">暂无文章，敬请期待</p>
    </section>
  )}
</BaseLayout>
