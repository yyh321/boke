---
export const prerender = false

import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getAllPosts } from '../../../lib/db/posts'

const posts = getAllPosts().sort(
  (a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime()
)
---

<AdminLayout title="文章管理">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">文章管理</h1>
    <a href="/admin/posts/new" class="px-4 py-2 bg-primary-600 text-white rounded-xl text-sm font-medium hover:bg-primary-700 transition-colors">
      写新文章
    </a>
  </div>

  {posts.length === 0 ? (
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg mb-4">还没有文章，开始写第一篇吧</p>
      <a href="/admin/posts/new" class="text-primary-600 hover:text-primary-700 font-medium">写新文章</a>
    </div>
  ) : (
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50">
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">标题</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">状态</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">分类</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">评论</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">更新时间</th>
            <th class="text-right px-6 py-3 text-sm font-medium text-gray-500">操作</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <a href={`/admin/posts/edit/${post.id}`} class="text-sm font-medium text-gray-900 hover:text-primary-600">
                  {post.title}
                </a>
              </td>
              <td class="px-6 py-4">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                  post.status === 'published' ? 'bg-green-100 text-green-700' :
                  post.status === 'draft' ? 'bg-yellow-100 text-yellow-700' :
                  'bg-blue-100 text-blue-700'
                }`}>
                  {post.status === 'published' ? '已发布' : post.status === 'draft' ? '草稿' : '定时发布'}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">{post.category}</td>
              <td class="px-6 py-4 text-sm text-gray-500">{post.commentCount}</td>
              <td class="px-6 py-4 text-sm text-gray-400">
                {new Date(post.updatedAt).toLocaleDateString('zh-CN')}
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href={`/admin/posts/edit/${post.id}`} class="text-sm text-primary-600 hover:text-primary-700">编辑</a>
                  <button class="delete-btn text-sm text-red-500 hover:text-red-700" data-id={post.id} data-title={post.title}>删除</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <script>
    document.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id
        const title = btn.dataset.title

        if (!confirm(`确定要删除文章「${title}」吗？此操作不可恢复。`)) return

        try {
          const res = await fetch('/api/posts', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          })
          const data = await res.json()
          if (data.success) {
            window.location.reload()
          } else {
            alert(data.error || '删除失败')
          }
        } catch {
          alert('网络错误')
        }
      })
    })
  </script>
</AdminLayout>
