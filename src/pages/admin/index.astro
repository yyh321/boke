---
export const prerender = false

import AdminLayout from '../../layouts/AdminLayout.astro'
import { getPostStatsAsync } from '../../lib/db/posts'
import { getCommentStatsAsync } from '../../lib/db/comments'

const postStats = await getPostStatsAsync()
const commentStats = await getCommentStatsAsync()
---

<AdminLayout title="仪表盘">
  <div id="redis-warning" class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-xl hidden">
    <div class="flex items-start gap-3">
      <span class="text-amber-500 text-xl">⚠️</span>
      <div>
        <p class="text-amber-800 font-semibold text-sm">Redis 存储未配置 - 文章数据可能丢失！</p>
        <p class="text-amber-600 text-sm mt-1">
          请在 Vercel 中配置 KV 存储。打开
          <a href="https://vercel.com/dashboard/stores" target="_blank" class="text-primary-600 underline font-medium">Vercel Storage</a>，
          创建 Redis 数据库后重新部署。
        </p>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">仪表盘</h1>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">文章总数</p>
      <p class="text-3xl font-bold text-gray-900">{postStats.total}</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">已发布</p>
      <p class="text-3xl font-bold text-green-600">{postStats.published}</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">草稿</p>
      <p class="text-3xl font-bold text-yellow-600">{postStats.draft}</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">定时发布</p>
      <p class="text-3xl font-bold text-blue-600">{postStats.scheduled}</p>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">评论总数</p>
      <p class="text-3xl font-bold text-gray-900">{commentStats.total}</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">待审核</p>
      <p class="text-3xl font-bold text-orange-600">{commentStats.pending}</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-200 p-6">
      <p class="text-sm text-gray-500 mb-1">已通过</p>
      <p class="text-3xl font-bold text-green-600">{commentStats.approved}</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <a href="/admin/posts/new" class="block bg-primary-600 text-white rounded-2xl p-8 hover:bg-primary-700 transition-colors">
      <h3 class="text-lg font-semibold mb-2">写新文章</h3>
      <p class="text-primary-100 text-sm">创建一篇新的博客文章</p>
    </a>
    <a href="/admin/comments" class="block bg-orange-600 text-white rounded-2xl p-8 hover:bg-orange-700 transition-colors">
      <h3 class="text-lg font-semibold mb-2">评论管理</h3>
      <p class="text-orange-100 text-sm">
        {commentStats.pending > 0 ? `有 ${commentStats.pending} 条评论待审核` : '暂无待审核评论'}
      </p>
    </a>
  </div>

  <div class="mt-8 bg-white rounded-2xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">数据状态</h2>
    </div>
    <div id="db-status" class="space-y-3">
      <div class="flex items-center gap-2 text-sm text-gray-500">
        <div class="inline-block w-4 h-4 border-2 border-gray-300 border-t-primary-500 rounded-full animate-spin" />
        检测数据状态...
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  async function checkDbStatus() {
    const el = document.getElementById('db-status')
    try {
      const res = await fetch('/api/posts?filter=published')
      const data = await res.json()
      const count = data.data ? data.data.length : 0
      el.innerHTML = `
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-700">数据库文章数: <strong>${count}</strong></p>
            <p class="text-xs text-gray-400 mt-1">
              ${count === 0
                ? '暂无数据，请先发布文章'
                : '数据正常'}
            </p>
          </div>
        </div>
      `
    } catch {
      el.innerHTML = '<p class="text-sm text-red-500">连接失败</p>'
    }
  }

  async function checkRedis() {
    try {
      const res = await fetch('/api/db-status')
      const data = await res.json()
      if (!data.data.hasRedis) {
        document.getElementById('redis-warning')?.classList.remove('hidden')
      }
    } catch {
      // ignore
    }
  }

  checkRedis()
  checkDbStatus()
</script>
