---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import SearchClient from '../components/SearchClient.astro'
---

<BaseLayout
  title="搜索"
  description="搜索博客文章内容"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="container-narrow py-16 animate-fade-in">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-8">
      搜索文章
    </h1>

    <SearchClient />
  </div>
</BaseLayout>
