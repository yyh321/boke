---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { getCollection } from 'astro:content'
import { getPublishedPostsAsync } from '../../lib/db/posts'

const { category } = Astro.params

const [contentPosts, dbPosts] = await Promise.all([
  getCollection('blog'),
  getPublishedPostsAsync(),
])

const contentArticles = contentPosts
  .filter((p) => !p.data.draft)
  .map((p) => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    category: p.data.category,
    tags: p.data.tags,
    readingTime: p.data.readingTime,
  }))

const dbArticles = dbPosts.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  pubDate: new Date(p.publishDate),
  category: p.category,
  tags: p.tags,
  readingTime: p.readingTime,
}))

const seen = new Set<string>()
const allArticles = [...dbArticles, ...contentArticles].filter((a) => {
  if (seen.has(a.slug)) return false
  seen.add(a.slug)
  return true
})

const filtered = allArticles
  .filter((a) => a.category === category)
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())
---

<BaseLayout
  title={`${category} - 分类`}
  description={`浏览 ${category} 分类下的文章`}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="container-main py-16 animate-fade-in">
    <nav class="mb-8" aria-label="面包屑导航">
      <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <li><a href="/categories" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">分类</a></li>
        <li><span aria-hidden="true">/</span></li>
        <li class="text-gray-900 dark:text-gray-100 font-medium" aria-current="page">{category}</li>
      </ol>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-2">
      {category}
    </h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      共 {filtered.length} 篇文章
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {filtered.map((post) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </div>
</BaseLayout>
