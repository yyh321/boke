---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { getCollection } from 'astro:content'
import { getPublishedPostsAsync } from '../../lib/db/posts'

const [contentPosts, dbPosts] = await Promise.all([
  getCollection('blog'),
  getPublishedPostsAsync(),
])

const contentArticles = contentPosts
  .filter((p) => !p.data.draft)
  .map((p) => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    category: p.data.category,
    tags: p.data.tags,
    readingTime: p.data.readingTime,
  }))

const dbArticles = dbPosts.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  pubDate: new Date(p.publishDate),
  category: p.category,
  tags: p.tags,
  readingTime: p.readingTime,
}))

const seen = new Set<string>()
const allArticles = [...dbArticles, ...contentArticles].filter((a) => {
  if (seen.has(a.slug)) return false
  seen.add(a.slug)
  return true
})

const categoryMap = new Map<string, typeof contentArticles>()
for (const a of allArticles) {
  const cat = a.category || '未分类'
  if (!categoryMap.has(cat)) categoryMap.set(cat, [])
  categoryMap.get(cat)!.push(a)
}

const categories = [...categoryMap.keys()].sort()
---

<BaseLayout
  title="文章分类"
  description="按分类浏览博客文章"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="container-main py-16 animate-fade-in">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-8">
      文章分类
    </h1>

    <div class="flex flex-wrap gap-3 mb-12">
      <a href="/categories" class="tag">全部分类</a>
      {categories.map((category) => (
        <a
          href={`/categories/${category}`}
          class="tag hover:bg-primary-100 dark:hover:bg-primary-900 transition-colors"
        >
          {category}
        </a>
      ))}
    </div>

    {categories.map((category) => {
      const categoryArticles = categoryMap.get(category) || []
      return (
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
            <span class="w-1 h-5 bg-primary-500 rounded-full" aria-hidden="true" />
            {category}
            <span class="text-sm font-normal text-gray-400 dark:text-gray-500">
              ({categoryArticles.length} 篇)
            </span>
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {categoryArticles.map((post) => (
              <ArticleCard post={post} />
            ))}
          </div>
        </section>
      )
    })}
  </div>
</BaseLayout>
