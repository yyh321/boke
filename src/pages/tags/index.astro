---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'
import { getPublishedPostsAsync } from '../../lib/db/posts'

const [contentPosts, dbPosts] = await Promise.all([
  getCollection('blog'),
  getPublishedPostsAsync(),
])

const contentArticles = contentPosts
  .filter((p) => !p.data.draft)
  .map((p) => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    category: p.data.category,
    tags: p.data.tags,
    readingTime: p.data.readingTime,
  }))

const dbArticles = dbPosts.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  pubDate: new Date(p.publishDate),
  category: p.category,
  tags: p.tags,
  readingTime: p.readingTime,
}))

const seen = new Set<string>()
const allArticles = [...dbArticles, ...contentArticles].filter((a) => {
  if (seen.has(a.slug)) return false
  seen.add(a.slug)
  return true
})

const tagCounts = new Map<string, number>()
for (const a of allArticles) {
  for (const tag of a.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1)
  }
}

const tags = [...tagCounts.keys()].sort()
---

<BaseLayout
  title="文章标签"
  description="按标签浏览博客文章"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="container-main py-16 animate-fade-in">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-8">
      文章标签
    </h1>

    <div class="flex flex-wrap gap-3 mb-12">
      {tags.map((tag) => {
        const count = tagCounts.get(tag) || 0
        const sizeClass = count > 3 ? 'text-base' : count > 1 ? 'text-sm' : 'text-xs'
        return (
          <a
            href={`/tags/${tag}`}
            class={`tag ${sizeClass} hover:bg-primary-100 dark:hover:bg-primary-900 transition-all`}
          >
            {tag}
            <span class="ml-1.5 opacity-60">({count})</span>
          </a>
        )
      })}
    </div>
  </div>
</BaseLayout>
