---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  image?: string
  type?: 'website' | 'article'
  pubDate?: Date
  tags?: string[]
}

const {
  title,
  description,
  image = '/og-image.png',
  type = 'website',
  pubDate,
  tags,
} = Astro.props

const siteUrl = 'https://your-blog-domain.com'
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href

const structuredData = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'Article' : 'WebPage',
  headline: title,
  description,
  image,
  url: canonicalURL,
  ...(pubDate && {
    datePublished: pubDate.toISOString(),
    dateModified: pubDate.toISOString(),
  }),
  ...(tags && { keywords: tags.join(', ') }),
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Your Name" />
    <meta name="theme-color" content="#0ea5e9" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="超越自我技术博客" />
    <meta property="og:locale" content="zh_CN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, siteUrl).href} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="超越自我技术博客 RSS" href="/rss.xml" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <title>{title} | 超越自我技术博客</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot name="header" />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
