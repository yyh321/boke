---
const isLoggedIn = Astro.cookies.has('admin_token')

if (isLoggedIn) {
  const expiresAt = new Date(Date.now() + 24 * 60 * 60 * 1000)
  const token = Astro.cookies.get('admin_token')?.value
  const session = Astro.cookies.get('admin_session')?.value

  if (token) {
    Astro.cookies.set('admin_token', token, {
      path: '/',
      expires: expiresAt,
      httpOnly: true,
      sameSite: 'lax',
    })
  }

  if (session) {
    Astro.cookies.set('admin_session', session, {
      path: '/',
      expires: expiresAt,
      sameSite: 'lax',
    })
  }
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{Astro.props.title || '管理后台'} | 超越自我技术博客</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 min-h-screen">
    {isLoggedIn && (
      <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <div class="flex items-center gap-8">
              <a href="/admin" class="text-lg font-bold text-gray-900">管理后台</a>
              <nav class="flex items-center gap-1">
                <a href="/admin" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors">仪表盘</a>
                <a href="/admin/posts" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors">文章管理</a>
                <a href="/admin/comments" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors">评论管理</a>
              </nav>
            </div>
            <div class="flex items-center gap-4">
              <a href="/" class="text-sm text-gray-500 hover:text-gray-700" target="_blank">查看博客</a>
              <button id="logout-btn" class="text-sm text-red-500 hover:text-red-700">退出登录</button>
            </div>
          </div>
        </div>
      </header>
    )}

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    {isLoggedIn && (
      <script>
        document.getElementById('logout-btn')?.addEventListener('click', async () => {
          await fetch('/api/auth', { method: 'DELETE' })
          window.location.href = '/admin/login'
        })

        setInterval(() => {
          fetch('/api/auth').catch(() => {})
        }, 10 * 60 * 1000)
      </script>
    )}
  </body>
</html>
