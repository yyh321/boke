\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">type\u003C/span>\u003Cspan style=\"color:#B392F0\"> Partial\u003C/span>\u003Cspan style=\"color:#E1E4E8\">&#x3C;\u003C/span>\u003Cspan style=\"color:#B392F0\">T\u003C/span>\u003Cspan style=\"color:#E1E4E8\">> \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">  [\u003C/span>\u003Cspan style=\"color:#B392F0\">P\u003C/span>\u003Cspan style=\"color:#F97583\"> in\u003C/span>\u003Cspan style=\"color:#F97583\"> keyof\u003C/span>\u003Cspan style=\"color:#B392F0\"> T\u003C/span>\u003Cspan style=\"color:#E1E4E8\">]\u003C/span>\u003Cspan style=\"color:#F97583\">?:\u003C/span>\u003Cspan style=\"color:#B392F0\"> T\u003C/span>\u003Cspan style=\"color:#E1E4E8\">[\u003C/span>\u003Cspan style=\"color:#B392F0\">P\u003C/span>\u003Cspan style=\"color:#E1E4E8\">]\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">}\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"模板字面量类型\">模板字面量类型\u003C/h2>\n\u003Cp>TypeScript 4.1 引入了模板字面量类型：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;\" tabindex=\"0\" data-language=\"typescript\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">type\u003C/span>\u003Cspan style=\"color:#B392F0\"> EventName\u003C/span>\u003Cspan style=\"color:#E1E4E8\">&#x3C;\u003C/span>\u003Cspan style=\"color:#B392F0\">T\u003C/span>\u003Cspan style=\"color:#F97583\"> extends\u003C/span>\u003Cspan style=\"color:#79B8FF\"> string\u003C/span>\u003Cspan style=\"color:#E1E4E8\">> \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> `on${\u003C/span>\u003Cspan style=\"color:#B392F0\">Capitalize\u003C/span>\u003Cspan style=\"color:#9ECBFF\">&#x3C;\u003C/span>\u003Cspan style=\"color:#B392F0\">T\u003C/span>\u003Cspan style=\"color:#9ECBFF\">>\u003C/span>\u003Cspan style=\"color:#9ECBFF\">}`\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">type\u003C/span>\u003Cspan style=\"color:#B392F0\"> ClickEvent\u003C/span>\u003Cspan style=\"color:#F97583\"> =\u003C/span>\u003Cspan style=\"color:#B392F0\"> EventName\u003C/span>\u003Cspan style=\"color:#E1E4E8\">&#x3C;\u003C/span>\u003Cspan style=\"color:#9ECBFF\">'click'\u003C/span>\u003Cspan style=\"color:#E1E4E8\">> \u003C/span>\u003Cspan style=\"color:#6A737D\">// 'onClick'\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch3 id=\"实用技巧\">实用技巧\u003C/h3>\n\u003Col>\n\u003Cli>使用 \u003Ccode>infer\u003C/code> 关键字在条件类型中推断类型\u003C/li>\n\u003Cli>结合 \u003Ccode>as const\u003C/code> 断言获取精确的字面量类型\u003C/li>\n\u003Cli>使用 \u003Ccode>satisfies\u003C/code> 操作符进行类型验证\u003C/li>\n\u003C/ol>\n\u003Cblockquote>\n\u003Cp>类型系统是 TypeScript 最强大的特性之一，掌握它能让你的代码更加健壮。\u003C/p>\n\u003C/blockquote>",{"headings":151,"localImagePaths":162,"remoteImagePaths":163,"frontmatter":164,"imagePaths":167},[152,154,156,158,160],{"depth":32,"slug":153,"text":153},"条件类型",{"depth":36,"slug":155,"text":155},"分布式条件类型",{"depth":32,"slug":157,"text":157},"映射类型",{"depth":32,"slug":159,"text":159},"模板字面量类型",{"depth":36,"slug":161,"text":161},"实用技巧",[],[],{"title":139,"description":140,"pubDate":165,"category":63,"tags":166,"featured":23},["Date","2025-11-20T00:00:00.000Z"],[143,66,144],[],"second-post.md","third-post",{"id":169,"data":171,"body":178,"filePath":179,"digest":180,"rendered":181,"legacyId":205},{"title":172,"description":173,"pubDate":174,"category":63,"tags":175,"draft":22,"featured":22},"CSS 现代布局完全指南","从 Flexbox 到 Grid，再到 Container Queries，掌握现代 CSS 布局方案",["Date","2025-10-10T00:00:00.000Z"],[176,66,177],"CSS","布局","## Flexbox 布局\n\nFlexbox 是一维布局方案，适合处理行或列方向的排列。\n\n```css\n.container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 1rem;\n}\n```\n\n### 常见场景\n\n- 导航栏布局\n- 卡片排列\n- 垂直居中\n\n## CSS Grid 布局\n\nGrid 是二维布局方案，同时处理行和列：\n\n```css\n.grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n  gap: 2rem;\n}\n```\n\n### 命名区域\n\n```css\n.layout {\n  display: grid;\n  grid-template-areas:\n    \"header header\"\n    \"sidebar main\"\n    \"footer footer\";\n}\n```\n\n## Container Queries\n\n容器查询让组件可以根据容器大小调整样式：\n\n```css\n@container (min-width: 600px) {\n  .card {\n    display: grid;\n    grid-template-columns: 1fr 2fr;\n  }\n}\n```\n\n### 最佳实践\n\n- 优先使用 Grid 进行整体页面布局\n- 组件内部使用 Flexbox\n- Container Queries 用于可复用组件","src/content/blog/third-post.md","59b365eb4408fb9c",{"html":182,"metadata":183},"\u003Ch2 id=\"flexbox-布局\">Flexbox 布局\u003C/h2>\n\u003Cp>Flexbox 是一维布局方案，适合处理行或列方向的排列。\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;\" tabindex=\"0\" data-language=\"css\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#B392F0\">.container\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#79B8FF\">  display\u003C/span>\u003Cspan style=\"color:#E1E4E8\">: \u003C/span>\u003Cspan style=\"color:#79B8FF\">flex\u003C/span>\u003Cspan style=\"color:#E1E4E8\">;\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#79B8FF\">  justify-content\u003C/span>\u003Cspan style=\"color:#E1E4E8\">: \u003C/span>\u003Cspan style=\"color:#79B8FF\">center\u003C/span>\u003Cspan style=\"color:#E1E4E8\">;\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#79B8FF\">  align-items\u003C/span>\u003Cspan style=\"color:#E1E4E8\">: \u003C/span>\u003Cspan style=\"color:#79B8FF\">center\u003C/span>\u003Cspan style=\"color:#E1E4E8\">;\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#79B8FF\">  gap\u003C/span>\u003C