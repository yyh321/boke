[["Map",1,2,9,10],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.1","content-config-digest","f6b58e90d801c379","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://your-blog-domain.com\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"where\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":false,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"@astrojs/vercel/dev-image-service\",\"config\":{\"sizes\":[640,750,828,1080,1200,1920,2048,3840],\"domains\":[],\"remotePatterns\":[{\"protocol\":\"https\"}]}},\"domains\":[],\"remotePatterns\":[{\"protocol\":\"https\"}],\"responsiveStyles\":false,\"breakpoints\":[640,750,828,1080,1200,1920,2048,3840]},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":true,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","blog",["Map",11,12,56,57,99,100,136,137,169,170],"life-post",{"id":11,"data":13,"body":24,"filePath":25,"digest":26,"rendered":27,"legacyId":55},{"title":14,"description":15,"pubDate":16,"category":17,"tags":18,"draft":22,"featured":23},"2025 年终总结与展望","回顾过去一年的成长与收获，展望新的一年的目标与计划",["Date","2025-12-31T00:00:00.000Z"],"生活",[19,20,21],"年终总结","成长","计划",false,true,"## 回顾 2025\n\n这一年是充实且充满收获的一年。\n\n### 技术成长\n\n- 深入学习了 Astro 和现代前端框架\n- 掌握了 TypeScript 高级类型系统\n- 参与了多个开源项目\n\n### 生活感悟\n\n> 成长不是一蹴而就的，而是日积月累的结果。\n\n## 开源贡献\n\n今年我主要贡献了以下项目：\n\n1. **Astro 中文文档** - 帮助完善了中文翻译\n2. **TypeScript 练习题库** - 创建了 100+ 练习题\n3. **个人博客系统** - 从零搭建了本博客\n\n## 2026 计划\n\n### 技术目标\n\n- 深入学习 Rust 编程语言\n- 掌握 WebAssembly 技术\n- 完成一个完整的全栈项目\n\n### 生活目标\n\n- 每周至少阅读一本书\n- 坚持技术写作\n- 参加技术分享活动\n\n> 新的一年，继续前行，保持学习的热情。","src/content/blog/life-post.md","83b28cd1d1f42d73",{"html":28,"metadata":29},"\u003Ch2 id=\"回顾-2025\">回顾 2025\u003C/h2>\n\u003Cp>这一年是充实且充满收获的一年。\u003C/p>\n\u003Ch3 id=\"技术成长\">技术成长\u003C/h3>\n\u003Cul>\n\u003Cli>深入学习了 Astro 和现代前端框架\u003C/li>\n\u003Cli>掌握了 TypeScript 高级类型系统\u003C/li>\n\u003Cli>参与了多个开源项目\u003C/li>\n\u003C/ul>\n\u003Ch3 id=\"生活感悟\">生活感悟\u003C/h3>\n\u003Cblockquote>\n\u003Cp>成长不是一蹴而就的，而是日积月累的结果。\u003C/p>\n\u003C/blockquote>\n\u003Ch2 id=\"开源贡献\">开源贡献\u003C/h2>\n\u003Cp>今年我主要贡献了以下项目：\u003C/p>\n\u003Col>\n\u003Cli>\u003Cstrong>Astro 中文文档\u003C/strong> - 帮助完善了中文翻译\u003C/li>\n\u003Cli>\u003Cstrong>TypeScript 练习题库\u003C/strong> - 创建了 100+ 练习题\u003C/li>\n\u003Cli>\u003Cstrong>个人博客系统\u003C/strong> - 从零搭建了本博客\u003C/li>\n\u003C/ol>\n\u003Ch2 id=\"2026-计划\">2026 计划\u003C/h2>\n\u003Ch3 id=\"技术目标\">技术目标\u003C/h3>\n\u003Cul>\n\u003Cli>深入学习 Rust 编程语言\u003C/li>\n\u003Cli>掌握 WebAssembly 技术\u003C/li>\n\u003Cli>完成一个完整的全栈项目\u003C/li>\n\u003C/ul>\n\u003Ch3 id=\"生活目标\">生活目标\u003C/h3>\n\u003Cul>\n\u003Cli>每周至少阅读一本书\u003C/li>\n\u003Cli>坚持技术写作\u003C/li>\n\u003Cli>参加技术分享活动\u003C/li>\n\u003C/ul>\n\u003Cblockquote>\n\u003Cp>新的一年，继续前行，保持学习的热情。\u003C/p>\n\u003C/blockquote>",{"headings":30,"localImagePaths":49,"remoteImagePaths":50,"frontmatter":51,"imagePaths":54},[31,35,38,40,42,45,47],{"depth":32,"slug":33,"text":34},2,"回顾-2025","回顾 2025",{"depth":36,"slug":37,"text":37},3,"技术成长",{"depth":36,"slug":39,"text":39},"生活感悟",{"depth":32,"slug":41,"text":41},"开源贡献",{"depth":32,"slug":43,"text":44},"2026-计划","2026 计划",{"depth":36,"slug":46,"text":46},"技术目标",{"depth":36,"slug":48,"text":48},"生活目标",[],[],{"title":14,"description":15,"pubDate":52,"category":17,"tags":53,"featured":23},["Date","2025-12-31T00:00:00.000Z"],[19,20,21],[],"life-post.md","first-post",{"id":56,"data":58,"body":68,"filePath":69,"digest":70,"rendered":71,"legacyId":98},{"title":59,"description":60,"pubDate":61,"updatedDate":62,"category":63,"tags":64,"draft":22,"featured":23},"从零开始搭建个人博客","使用 Astro 框架构建一个高性能、SEO 友好的个人博客网站，记录技术成长与生活感悟",["Date","2025-12-15T00:00:00.000Z"],["Date","2025-12-20T00:00:00.000Z"],"技术",[65,66,67],"Astro","前端","博客","## 为什么选择 Astro\n\nAstro 是一个现代化的静态站点生成器，它提供了出色的开发体验和用户体验。\n\n### 岛屿架构\n\nAstro 的岛屿架构（Islands Architecture）允许我们按需加载交互组件，这意味着页面的大部分内容都是静态 HTML，只有需要交互的部分才会加载 JavaScript。\n\n### 内容集合\n\nContent Collections 提供了类型安全的内容管理方式，让我们可以轻松管理 Markdown 和 MDX 文章。\n\n## 快速开始\n\n```bash\n# 创建项目\nnpm create astro@latest\n\n# 启动开发服务器\nnpm run dev\n```\n\n### 项目结构\n\n```\nsrc/\n  content/    # 文章内容\n  layouts/    # 布局组件\n  components/ # 可复用组件\n  pages/      # 页面文件\n```\n\n## 性能优化\n\nAstro 默认生成为静态 HTML，这使得首屏加载极快。配合以下优化策略，可以获得更好的性能：\n\n1. **图片优化** - 使用 Astro 内置的 Image 组件\n2. **代码分割** - 岛屿架构自动完成\n3. **预加载** - 智能预加载关键资源\n\n> Astro 的目标是让 Web 更快，而它确实做到了。\n\n### Lighthouse 评分\n\n优化后的 Astro 网站通常可以达到 100 分的 Lighthouse 性能评分，包括最佳实践和 SEO 类别。","src/content/blog/first-post.md","d210476e4b2fe4e4",{"html":72,"metadata":73},"\u003Ch2 id=\"为什么选择-astro\">为什么选择 Astro\u003C/h2>\n\u003Cp>Astro 是一个现代化的静态站点生成器，它提供了出色的开发体验和用户体验。\u003C/p>\n\u003Ch3 id=\"岛屿架构\">岛屿架构\u003C/h3>\n\u003Cp>Astro 的岛屿架构（Islands Architecture）允许我们按需加载交互组件，这意味着页面的大部分内容都是静态 HTML，只有需要交互的部分才会加载 JavaScript。\u003C/p>\n\u003Ch3 id=\"内容集合\">内容集合\u003C/h3>\n\u003Cp>Content Collections 提供了类型安全的内容管理方式，让我们可以轻松管理 Markdown 和 MDX 文章。\u003C/p>\n\u003Ch2 id=\"快速开始\">快速开始\u003C/h2>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;\" tabindex=\"0\" data-language=\"bash\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 创建项目\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#B392F0\">npm\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> create\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> astro@latest\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#6A737D\"># 启动开发服务器\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#B392F0\">npm\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> run\u003C/span>\u003Cspan style=\"color:#9ECBFF\"> dev\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch3 id=\"项目结构\">项目结构\u003C/h3>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;\" tabindex=\"0\" data-language=\"plaintext\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan>src/\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>  content/    # 文章内容\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>  layouts/    # 布局组件\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>  components/ # 可复用组件\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan>  pages/      # 页面文件\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch2 id=\"性能优化\">性能优化\u003C/h2>\n\u003Cp>Astro 默认生成为静态 HTML，这使得首屏加载极快。配合以下优化策略，可以获得更好的性能：\u003C/p>\n\u003Col>\n\u003Cli>\u003Cstrong>图片优化\u003C/strong> - 使用 Astro 内置的 Image 组件\u003C/li>\n\u003Cli>\u003Cstrong>代码分割\u003C/strong> - 岛屿架构自动完成\u003C/li>\n\u003Cli>\u003Cstrong>预加载\u003C/strong> - 智能预加载关键资源\u003C/li>\n\u003C/ol>\n\u003Cblockquote>\n\u003Cp>Astro 的目标是让 Web 更快，而它确实做到了。\u003C/p>\n\u003C/blockquote>\n\u003Ch3 id=\"lighthouse-评分\">Lighthouse 评分\u003C/h3>\n\u003Cp>优化后的 Astro 网站通常可以达到 100 分的 Lighthouse 性能评分，包括最佳实践和 SEO 类别。\u003C/p>",{"headings":74,"localImagePaths":91,"remoteImagePaths":92,"frontmatter":93,"imagePaths":97},[75,78,80,82,84,86,88],{"depth":32,"slug":76,"text":77},"为什么选择-astro","为什么选择 Astro",{"depth":36,"slug":79,"text":79},"岛屿架构",{"depth":36,"slug":81,"text":81},"内容集合",{"depth":32,"slug":83,"text":83},"快速开始",{"depth":36,"slug":85,"text":85},"项目结构",{"depth":32,"slug":87,"text":87},"性能优化",{"depth":36,"slug":89,"text":90},"lighthouse-评分","Lighthouse 评分",[],[],{"title":59,"description":60,"pubDate":94,"updatedDate":95,"category":63,"tags":96,"featured":23},["Date","2025-12-15T00:00:00.000Z"],["Date","2025-12-20T00:00:00.000Z"],[65,66,67],[],"first-post.md","design-post",{"id":99,"data":101,"body":108,"filePath":109,"digest":110,"rendered":111,"legacyId":135},{"title":102,"description":103,"pubDate":104,"category":63,"tags":105,"draft":22,"featured":22},"设计模式在前端开发中的应用","探索常见设计模式在前端开发中的实际应用场景，提升代码可维护性和可扩展性",["Date","2025-09-15T00:00:00.000Z"],[106,66,107],"设计模式","架构","## 单例模式\n\n单例模式确保一个类只有一个实例：\n\n```typescript\nclass Store {\n  private static instance: Store\n\n  private constructor() {}\n\n  static getInstance(): Store {\n    if (!Store.instance) {\n      Store.instance = new Store()\n    }\n    return Store.instance\n  }\n}\n```\n\n### 在前端中的应用\n\n- 状态管理 Store\n- 全局配置对象\n- 缓存管理\n\n## 观察者模式\n\n观察者模式定义了一对多的依赖关系：\n\n```typescript\ninterface Observer {\n  update(data: unknown): void\n}\n\nclass Subject {\n  private observers: Observer[] = []\n\n  subscribe(observer: Observer): void {\n    this.observers.push(observer)\n  }\n\n  notify(data: unknown): void {\n    this.observers.forEach((o) => o.update(data))\n  }\n}\n```\n\n### 在前端中的应用\n\n- 事件系统\n- 响应式数据绑定\n- WebSocket 消息处理\n\n## 工厂模式\n\n工厂模式封装了对象创建的逻辑：\n\n```typescript\ninterface Component {\n  render(): void\n}\n\nclass Button implements Component {\n  render() { /* ... */ }\n}\n\nclass Input implements Component {\n  render() { /* ... */ }\n}\n\nclass ComponentFactory {\n  static create(type: string): Component {\n    switch (type) {\n      case 'button': return new Button()\n      case 'input': return new Input()\n      default: throw new Error('Unknown component')\n    }\n  }\n}\n```\n\n## 策略模式\n\n策略模式定义了一系列可互换的算法：\n\n```typescript\ninterface ValidationStrategy {\n  validate(value: string): boolean\n}\n\nclass EmailValidation implements ValidationStrategy {\n  validate(value: string): boolean {\n    return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(value)\n  }\n}\n\nclass PhoneValidation implements ValidationStrategy {\n  validate(value: string): boolean {\n    return /^\\d{11}$/.test(value)\n  }\n}\n```\n\n### 最佳实践\n\n- 合理使用设计模式，不要过度设计\n- 优先考虑组合而非继承\n- 结合实际业务场景选择合适的设计模式","src/content/blog/design-post.md","eef3344ab5d8565a",{"html":112,"metadata":113},"\u003Ch2 id=\"单例模式\">单例模式\u003C/h2>\n\u003Cp>单例模式确保一个类只有一个实例：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;\" tabindex=\"0\" data-language=\"typescript\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">class\u003C/span>\u003Cspan style=\"color:#B392F0\"> Store\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">  private\u003C/span>\u003Cspan style=\"color:#F97583\"> static\u003C/span>\u003Cspan style=\"color:#FFAB70\"> instance\u003C/span>\u003Cspan style=\"color:#F97583\">:\u003C/span>\u003Cspan style=\"color:#B392F0\"> Store\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">  private\u003C/span>\u003Cspan style=\"color:#F97583\"> constructor\u003C/span>\u003Cspan style=\"color:#E1E4E8\">() {}\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">  static\u003C/span>\u003Cspan style=\"color:#B392F0\"> getInstance\u003C/span>\u003Cspan style=\"color:#E1E4E8\">()\u003C/span>\u003Cspan style=\"color:#F97583\">:\u003C/span>\u003Cspan style=\"color:#B392F0\"> Store\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">    if\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> (\u003C/span>\u003Cspan style=\"color:#F97583\">!\u003C/span>\u003Cspan style=\"color:#E1E4E8\">Store.instance) {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">      Store.instance \u003C/span>\u003Cspan style=\"color:#F97583\">=\u003C/span>\u003Cspan style=\"color:#F97583\"> new\u003C/span>\u003Cspan style=\"color:#B392F0\"> Store\u003C/span>\u003Cspan style=\"color:#E1E4E8\">()\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">    }\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">    return\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> Store.instance\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">  }\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#E1E4E8\">}\u003C/span>\u003C/span>\u003C/code>\u003C/pre>\n\u003Ch3 id=\"在前端中的应用\">在前端中的应用\u003C/h3>\n\u003Cul>\n\u003Cli>状态管理 Store\u003C/li>\n\u003Cli>全局配置对象\u003C/li>\n\u003Cli>缓存管理\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"观察者模式\">观察者模式\u003C/h2>\n\u003Cp>观察者模式定义了一对多的依赖关系：\u003C/p>\n\u003Cpre class=\"astro-code github-dark\" style=\"background-color:#24292e;color:#e1e4e8; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word;\" tabindex=\"0\" data-language=\"typescript\">\u003Ccode>\u003Cspan class=\"line\">\u003Cspan style=\"color:#F97583\">interface\u003C/span>\u003Cspan style=\"color:#B392F0\"> Observer\u003C/span>\u003Cspan style=\"color:#E1E4E8\"> {\u003C/span>\u003C/span>\n\u003Cspan class=\"line\">\u003Cspan style=\"color:#B392F0\">  update\u003C/span>\u003Cspan style=\"color:#E1E4E8\">(\u003C/span>\u003